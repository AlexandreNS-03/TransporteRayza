# URL pública del backend. En desarrollo usa http://localhost:8080 si no se define.
# Producción: VITE_API_URL=https://transporterayza-production.up.railway.app
VITE_API_URL=

# La pasarela Izipay NO necesita ninguna llave acá: la clave pública viaja desde el
# backend junto con el formToken de cada compra. Las credenciales se configuran solo
# en el servidor (IZIPAY_* en Railway).
