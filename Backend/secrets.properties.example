# Copia este archivo como "secrets.properties" (en la carpeta Backend/) y completa los valores.
# secrets.properties está en .gitignore y NUNCA debe subirse al repositorio.
DB_PASSWORD=tu-password-de-mysql
MAIL_PASSWORD=tu-app-password-de-gmail
JWT_SECRET=una-clave-larga-de-al-menos-256-bits-cambiala
NUBEFACT_URL=https://api.nubefact.com/api/v1/tu-ruta
NUBEFACT_TOKEN=tu-token-de-nubefact
APISPERU_TOKEN=tu-token-de-apisperu-para-consulta-dni-ruc

# ── Culqi (pasarela de pago en línea) — OPCIONAL ──
# Sin estas líneas el backend cobra en MODO SIMULACIÓN (no cobra de verdad).
# Para cobrar realmente, descomenta y usa tus llaves de https://panel.culqi.com
# CULQI_ENABLED=true
# CULQI_SECRET_KEY=sk_test_tu-llave-privada-de-culqi
